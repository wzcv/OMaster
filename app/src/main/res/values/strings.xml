    <!-- Color Walk 主题描述 -->
    <string name="colorwalk_desc_urban_warm">寻找红砖建筑、木质门窗、暖色灯光，捕捉城市的温暖质感</string>
    <string name="colorwalk_desc_seaside_fresh">海边、天空、沙滩，用清新蓝白色调记录海滨的宁静与开阔</string>
    <string name="colorwalk_desc_forest_green">公园、树木、草地，在绿色中寻找自然的生机与宁静</string>
    <string name="colorwalk_desc_industrial_cool">钢结构、工厂、桥梁，用冷色调展现工业美学的力量感</string>
    <string name="colorwalk_desc_sunset_glow">黄昏、天际线，捕捉落日余晖下城市的浪漫与温柔</string>
    <string name="colorwalk_desc_neon_night">夜市、霓虹灯牌，在夜色中寻找城市最炫目的色彩</string>
    <string name="colorwalk_desc_vintage_film">老街、旧物、复古场景，用胶片色调记录时光的痕迹</string>
    <string name="colorwalk_desc_minimalist_bw">建筑线条、光影对比，用极简黑白展现纯粹的形式美</string>
    <string name="colorwalk_desc_spring_blossom">花海、公园、春日街景，用粉嫩色调记录春天的浪漫</string>
    <string name="colorwalk_desc_coffee_time">咖啡馆、书店、文艺小店，用暖棕色调记录悠闲时光</string>
    <string name="colorwalk_desc_ocean_deep">深海、水族馆、蓝色建筑，用深蓝调探索神秘的海洋世界</string>
    <string name="colorwalk_desc_autumn_leaves">落叶、秋林、金色街道，用暖色调捕捉秋天的诗意</string>

    <!-- Color Walk 拍摄要点 -->
    <string name="colorwalk_tips_urban_warm">【寻找场景】红砖墙、老建筑、木质门框、暖色路灯【构图技巧】利用光影对比增强层次感，暖色调适合逆光拍摄【最佳时间】下午 3-5 点，阳光斜射时</string>
    <string name="colorwalk_tips_seaside_fresh">【寻找场景】海边栈道、蓝天白云、沙滩、白色建筑【构图技巧】大面积留白营造开阔感，水平线构图最佳【最佳时间】晴天上午，天空最蓝时</string>
    <string name="colorwalk_tips_forest_green">【寻找场景】公园树林、草地、藤蔓、苔藓【构图技巧】利用前景树叶增加层次，寻找阳光穿透树叶的光斑【最佳时间】清晨或傍晚，光线柔和时</string>
    <string name="colorwalk_tips_industrial_cool">【寻找场景】钢铁桥梁、工厂外墙、管道、混凝土建筑【构图技巧】强调几何线条，低角度拍摄增强力量感【最佳时间】阴天，光线均匀时</string>
    <string name="colorwalk_tips_sunset_glow">【寻找场景】城市天际线、高楼剪影、水面倒影【构图技巧】逆光拍摄剪影效果，利用水面反射增强色彩【最佳时间】日落后 20 分钟蓝调时刻</string>
    <string name="colorwalk_tips_neon_night">【寻找场景】商业街霓虹灯、夜市招牌、车流光轨【构图技巧】适当欠曝保留霓虹细节，利用光晕营造氛围【最佳时间】夜晚 8-10 点，霓虹灯全亮时</string>
    <string name="colorwalk_tips_vintage_film">【寻找场景】老街巷、旧书店、复古咖啡馆、老物件【构图技巧】寻找有年代感的元素，适当留白营造故事感【最佳时间】下午柔和光线，或室内暖光</string>
    <string name="colorwalk_tips_minimalist_bw">【寻找场景】现代建筑、几何线条、光影对比强烈的场景【构图技巧】简化构图，强调形状和纹理，注意留白【最佳时间】晴天，光影对比最强烈时</string>
    <string name="colorwalk_tips_spring_blossom">【寻找场景】樱花道、花海、公园、春日街景【构图技巧】利用前景花朵虚化营造梦幻感，浅景突出主体【最佳时间】清晨或傍晚，光线柔和时</string>
    <string name="colorwalk_tips_coffee_time">【寻找场景】咖啡馆内部、书架、咖啡杯、文艺小店【构图技巧】利用窗户侧光，暖色调适合拍摄静物和人物【最佳时间】下午 2-4 点，室内光线最佳</string>
    <string name="colorwalk_tips_ocean_deep">【寻找场景】海洋馆、蓝色外墙、深水池、雨天场景【构图技巧】利用水面反射和折射，深色背景突出主体【最佳时间】阴天或室内，光线较暗时</string>
    <string name="colorwalk_tips_autumn_leaves">【寻找场景】落叶大道、枫树林、秋日公园、金色田野【构图技巧】利用落叶做前景，逆光拍摄树叶透明感【最佳时间】晴天下午，阳光穿透树叶时</string>

